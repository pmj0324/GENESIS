# 데이터 / 모델 (용량 큰 바이너리)
*.npy
*.pt
*.pth
*.ckpt
*.h5

# 로그 텍스트
logs/

# 출력물 (재생성 가능)
outputs/

# 실험 결과 (runs/)
# runs/ 아래는 재현용 메타 파일(yaml/yml/txt)만 Git에 남기고,
# 나머지 산출물은 모두 ignore 한다.
runs/**
!runs/**/
!runs/**/*.yaml
!runs/**/*.yml
!runs/**/*.txt
scripts/**/*.png

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# 환경
.env
.venv
venv/
env/

# 에디터
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
